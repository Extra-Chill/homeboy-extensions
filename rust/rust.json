{
  "name": "Rust",
  "version": "1.4.0",
  "icon": "gearshape.2.fill",
  "description": "Cargo CLI integration for Rust components",
  "author": "Extra Chill",
  "provides": {
    "file_extensions": ["rs"],
    "capabilities": ["fingerprint", "refactor"]
  },
  "scripts": {
    "fingerprint": "scripts/fingerprint.sh",
    "refactor": "scripts/refactor.sh"
  },
  "audit": {
    "feature_patterns": [
      "#\\[derive\\(.*Subcommand.*\\)\\]\\s*(?:pub\\s+)?enum\\s+(\\w+)",
      "#\\[command\\(name\\s*=\\s*\"([^\"]+)\"\\)\\]",
      "pub struct (\\w+Args)\\s*\\{",
      "#\\[derive\\(.*Serialize.*Deserialize.*\\)\\]\\s*(?:pub\\s+)?struct\\s+(\\w+Config)\\b",
      "#\\[derive\\(.*Serialize.*Deserialize.*\\)\\]\\s*(?:pub\\s+)?struct\\s+(\\w+Manifest)\\b"
    ],
    "feature_labels": {
      "Subcommand": "Subcommands",
      "command\\(name": "CLI Commands",
      "Args)\\s*\\{": "Command Arguments",
      "Config)\\b": "Config Structures",
      "Manifest)\\b": "Manifest Structures"
    },
    "feature_context": {
      "Subcommand": { "doc_comment": true, "block_fields": true },
      "Args)\\s*\\{": { "doc_comment": true, "block_fields": true },
      "Config)\\b": { "doc_comment": true, "block_fields": true },
      "Manifest)\\b": { "doc_comment": true, "block_fields": true }
    },
    "doc_targets": {
      "Subcommands": {
        "file": "cli-reference.md",
        "heading": "## Subcommands",
        "template": "### `{name}`\n\n{description}\n\n{fields}"
      },
      "CLI Commands": {
        "file": "cli-reference.md",
        "heading": "## Commands",
        "template": "- `{name}` — {description}"
      },
      "Command Arguments": {
        "file": "cli-reference.md",
        "heading": "## Command Arguments",
        "template": "### `{name}`\n\n{description}\n\n{fields}"
      },
      "Config Structures": {
        "file": "architecture.md",
        "heading": "## Configuration",
        "template": "### `{name}`\n\n{description}\n\n{fields}"
      },
      "Manifest Structures": {
        "file": "architecture.md",
        "heading": "## Manifests",
        "template": "### `{name}`\n\n{description}\n\n{fields}"
      }
    }
  },
  "build": {
    "cleanup_paths": [
      "target"
    ]
  },
  "cli": {
    "tool": "cargo",
    "display_name": "Cargo",
    "command_template": "{{cliPath}} {{args}}",
    "working_dir_template": "{{sitePath}}",
    "default_cli_path": "cargo"
  },
  "actions": [
    {
      "id": "release.package",
      "label": "Package release artifacts",
      "type": "command",
      "command": "bash \"{{extension_path}}/scripts/package.sh\"",
      "payload": {
        "release": "{{payload.release}}",
        "config": "{{payload.config}}"
      }
    },
    {
      "id": "release.publish",
      "label": "Publish to crates.io",
      "type": "command",
      "command": "bash \"{{extension_path}}/scripts/publish-crates.sh\"",
      "payload": {
        "release": "{{payload.release}}",
        "config": "{{payload.config}}"
      }
    }
  ]
}
